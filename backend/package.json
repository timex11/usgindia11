{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "npx nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch --type-check",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:gen": "npx prisma generate",
    "prisma:seed": "npx prisma db seed",
    "debug-env": "node -v && dir",
    "db:init": "ts-node scripts/init_supabase.ts",
    "db:update": "ts-node scripts/update_schema.ts",
    "db:test": "ts-node scripts/test_db.ts",
    "db:verify": "node scripts/verify_system.js",
    "db:hardening": "ts-node scripts/admin_hardening_schema.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@bull-board/api": "^6.19.0",
    "@bull-board/express": "^6.19.0",
    "@bull-board/nestjs": "^6.19.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.12",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.91.1",
    "@types/pg": "^8.16.0",
    "axios": "^1.13.5",
    "bullmq": "^5.67.1",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cron": "^4.4.0",
    "helmet": "^8.1.0",
    "inflight": "^1.0.6",
    "ioredis": "^5.9.2",
    "nestjs-pino": "^4.6.0",
    "nestjs-zod": "^5.1.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.17.2",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "systeminformation": "^5.31.1",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6",
    "zod-nestjs": "^1.9.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/engines": "^5.22.0",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.11",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "glob": "^11.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "pm2": "^6.0.14",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
